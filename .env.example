# ============================================
# QUANTUM HORIZON — Environment Variables
# ============================================
# Скопируйте этот файл в .env.local и заполните значениями

# ============================================
# NEXT.JS
# ============================================
NEXT_PUBLIC_APP_NAME="Quantum Horizon"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Quantum Horizon"
# PORT=0  # 0 = автовыбор порта, или укажите конкретный (3000, 3001, etc.)

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
# Генерация: openssl rand -base64 32
# Или: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OAuth провайдеры (опционально)
# Google OAuth: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth: https://github.com/settings/developers
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# ============================================
# DATABASE (Prisma ORM)
# ============================================

# PostgreSQL (рекомендуется для production)
# Формат: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/quantum_horizon?schema=public"

# SQLite (для локальной разработки)
# DATABASE_URL="file:./prisma/dev.db"

# ============================================
# ANALYTICS (опционально)
# ============================================
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_POSTHOG_KEY="phc_XXXXXXXXXX"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ============================================
# API KEYS (опционально)
# ============================================
# NASA API Key: https://api.nasa.gov/
NEXT_PUBLIC_NASA_API_KEY="DEMO_KEY"

# ESA API Key (опционально)
# NEXT_PUBLIC_ESA_API_KEY="your-esa-api-key"

# Роскосмос API (опционально)
# NEXT_PUBLIC_ROSCOSMOS_API_KEY="your-roscosmos-api-key"
# NASA_API_KEY="your-nasa-api-key"
# OPEN_AI_API_KEY="your-openai-api-key"
# HUBBLE_API_KEY="your-hubble-api-key"

# ============================================
# EMAIL (опционально, для уведомлений)
# ============================================
# EMAIL_SERVER_HOST="smtp.example.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="user@example.com"
# EMAIL_SERVER_PASSWORD="password"
# EMAIL_FROM="noreply@example.com"

# ============================================
# REDIS (опционально, для кэширования)
# ============================================
# REDIS_URL="redis://localhost:6379"

# ============================================
# UPSTASH REDIS (для rate limiting)
# ============================================
# Создать на https://console.upstash.com/redis
# UPSTASH_REDIS_REST_URL="https://xxx.xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# ============================================
# SENTRY (опционально, для мониторинга ошибок)
# ============================================
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="quantum-horizon"
